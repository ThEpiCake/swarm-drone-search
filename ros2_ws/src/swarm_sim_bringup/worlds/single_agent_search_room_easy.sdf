    <!-- ════════════════════════════════════════════
         ROOM A — GROUND FLOOR
         Atrium inner opening: X=-3→+3, Y=-3→+3 (6×6 m).
         No balcony on east side (ח/C shape — open toward corridor).
         Balcony slab bottom: Z=5.0 m → scan layers 1m/2m/3m/4m AGL all clear.
    ════════════════════════════════════════════ -->

    <!-- Inner atrium support columns — 5 m tall. South stair-side columns removed. -->
    <model name="col_inner_sw">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 0.3 5.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.3 0.3 5.0</size></box></geometry>
          <material><ambient>0.42 0.38 0.32 1</ambient><diffuse>0.52 0.48 0.40 1</diffuse></material>
        </visual>
      </link>
      <pose>-3.0 -3.0 2.5 0 0 0</pose>
    </model>

    <model name="col_inner_nw">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 0.3 5.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.3 0.3 5.0</size></box></geometry>
          <material><ambient>0.42 0.38 0.32 1</ambient><diffuse>0.52 0.48 0.40 1</diffuse></material>
        </visual>
      </link>
      <pose>-3.0 3.0 2.5 0 0 0</pose>
    </model>

    <!-- Mid-arm column: north arm only. The south column was removed after the
         2026-06-23 run showed a VFH turn-stop against the stair-side pillar. -->
    <model name="col_inner_ne">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 0.3 5.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.3 0.3 5.0</size></box></geometry>
          <material><ambient>0.42 0.38 0.32 1</ambient><diffuse>0.52 0.48 0.40 1</diffuse></material>
        </visual>
      </link>
      <pose>3.0 3.0 2.5 0 0 0</pose>
    </model>

    <!-- North east-end arm column near east wall (south counterpart removed). -->
    <model name="col_arm_n_east">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 0.3 5.0</size></box></geometry></collision>
